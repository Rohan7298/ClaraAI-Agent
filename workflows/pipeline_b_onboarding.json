            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save v2 Agent Spec": {
      "main": [
        [
          {
            "node": "Log Task",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save Changelog": {
      "main": [
        [
          {
            "node": "Log Task",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": {},
  "versionId": "onboarding-workflow-v1"
}