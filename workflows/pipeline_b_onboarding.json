            "index": 0
          }
        ]
      ]
    },
    "Read Onboarding File": {
      "main": [
        [
          {
            "node": "Extract Updates",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Updates": {
      "main": [
        [
          {
