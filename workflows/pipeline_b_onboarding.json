            "index": 0
          }
        ]
      ]
    },
    "Post-process Updates": {
      "main": [
        [
          {
            "node": "Read v1 Memo",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read v1 Memo": {
      "main": [
        [
          {
            "node": "Prepare Merge",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Merge": {
      "main": [
        [
          {
            "node": "Apply Updates",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Apply Updates": {
      "main": [
        [
          {
            "node": "Post-process v2 Memo",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Post-process v2 Memo": {
      "main": [
        [
          {
            "node": "Generate v2 Agent Spec",
            "type": "main",
            "index": 0
          },
          {
            "node": "Prepare Diff",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate v2 Agent Spec": {
