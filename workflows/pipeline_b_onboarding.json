        [
          {
            "node": "Post-process v2 Spec",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Post-process v2 Spec": {
      "main": [
        [
          {
            "node": "Save v2 Memo",
            "type": "main",
            "index": 0
          },
          {
            "node": "Save v2 Agent Spec",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Diff": {
